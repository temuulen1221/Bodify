# API and integration secrets

# 🤖 AI AVATAR
# The AI chat coach routes ALL requests through Firebase Functions.
# Store the backend key as a Firebase secret:
#   firebase functions:secrets:set GOOGLE_GENAI_API_KEY
#
# EXPO_PUBLIC_GEMINI_LIVE_API_KEY is ONLY for the Gemini Live WebSocket
# service (real-time audio streaming) which requires a direct client connection.
EXPO_PUBLIC_GEMINI_LIVE_API_KEY=

# Client-side Gemini API key for direct fallback (used when Firebase Functions are
# unavailable or on Spark plan). Also auto-activates in __DEV__ mode on any platform.
# Get a key at https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=

# Set to true to force direct client-side Gemini (bypasses Firebase Functions entirely)
EXPO_PUBLIC_USE_DIRECT_GEMINI_FALLBACK=false

# Optional client-side live / experimental Gemini configuration
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash
EXPO_PUBLIC_GEMINI_MAX_TOKENS=1000
EXPO_PUBLIC_GEMINI_TEMPERATURE=0.7

# Firebase callable functions configuration
EXPO_PUBLIC_FUNCTIONS_REGION=us-central1
EXPO_PUBLIC_FUNCTIONS_EMULATOR_HOST=
EXPO_PUBLIC_FUNCTIONS_EMULATOR_PORT=

# 🍎 NUTRITION & DIET
SPOONACULAR_API_KEY=

# 💪 EXERCISE DATABASE
EXERCISEDB_API_KEY=
EXERCISEDB_API_HOST=exercisedb.p.rapidapi.com
EXERCISEDB_BASE_URL=https://exercisedb.p.rapidapi.com

# 🏃 STRAVA INTEGRATION
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# 🗺️ GOOGLE MAPS
# Recommended: use separate restricted keys per platform.
EXPO_PUBLIC_GOOGLE_MAPS_WEB_API_KEY=
GOOGLE_MAPS_ANDROID_API_KEY=
GOOGLE_MAPS_IOS_API_KEY=

# 🔐 GOOGLE OAUTH CLIENT IDS
# Keep these in sync with Firebase/Google Cloud OAuth clients for your app.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# 📱 IOS APP IDENTITY
IOS_BUNDLE_IDENTIFIER=com.temuulen1221.bodify
