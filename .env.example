# API and integration secrets

# 🤖 AI AVATAR
# Standard AI chat should use Firebase Functions with the GOOGLE_GENAI_API_KEY
# secret configured on the backend. Do not rely on a public Expo Gemini key for
# normal assistant requests.
#
# Only use this Expo public key if you intentionally keep direct client-side
# Gemini Live / experimental web-only flows.
EXPO_PUBLIC_GEMINI_API_KEY=

# Set to true to allow normal AI chat to fall back to direct client-side Gemini
# when Firebase Functions cannot be deployed on Spark or are temporarily unavailable.
EXPO_PUBLIC_USE_DIRECT_GEMINI_FALLBACK=false

# Optional client-side live / experimental Gemini configuration
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash
EXPO_PUBLIC_GEMINI_MAX_TOKENS=1000
EXPO_PUBLIC_GEMINI_TEMPERATURE=0.7

# Firebase callable functions configuration
EXPO_PUBLIC_FUNCTIONS_REGION=us-central1
EXPO_PUBLIC_FUNCTIONS_EMULATOR_HOST=
EXPO_PUBLIC_FUNCTIONS_EMULATOR_PORT=

# 🍎 NUTRITION & DIET
SPOONACULAR_API_KEY=

# 💪 EXERCISE DATABASE
EXERCISEDB_API_KEY=
EXERCISEDB_API_HOST=exercisedb.p.rapidapi.com
EXERCISEDB_BASE_URL=https://exercisedb.p.rapidapi.com

# 🏃 STRAVA INTEGRATION
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# 🗺️ GOOGLE MAPS
# Recommended: use separate restricted keys for web and Android.
EXPO_PUBLIC_GOOGLE_MAPS_WEB_API_KEY=
GOOGLE_MAPS_ANDROID_API_KEY=
